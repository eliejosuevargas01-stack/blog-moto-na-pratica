datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  id             String   @id @default(uuid())
  slug           String   @unique
  tag            String   // Ex: Review, Manutenção, Rotas, Equipamentos
  category       String
  title          String
  excerpt        String   @db.Text
  date           DateTime @default(now())
  readTime       String   // Ex: "8 min"
  img            String   // Imagem destacada (URL ou caminho do upload local)
  imgFocalPoint  String   @default("center") // Ponto focal CSS da imagem (ex: "center", "top", "50% 50%")

  // Blocos dinâmicos de Texto/Imagem: [{ text: string, image: string, focalPoint: string }]
  blocks         Json     

  // Campos de SEO customizados
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Campos de engajamento
  views          Int      @default(0)
  likes          Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comments       Comment[]
}

model Page {
  id             String   @id @default(uuid())
  slug           String   @unique // Ex: "home", "sobre", "contato"
  title          String
  isStatic       Boolean  @default(false) // Define se é uma página estática estruturada (Home, Sobre) ou customizada

  // Conteúdo estruturado da página (JSON)
  content        Json     

  // Campos de SEO customizados
  seoTitle       String?
  seoDescription String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  comments     Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // REGISTER, COMMENT, LIKE, SHARE
  message   String
  postId    String?
  postTitle String?
  userEmail String?
  userName  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

