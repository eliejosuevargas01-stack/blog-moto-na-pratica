datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  id             String   @id @default(uuid())
  slug           String   @unique
  tag            String   // Ex: Review, Manutenção, Rotas, Equipamentos
  category       String
  title          String
  excerpt        String   @db.Text
  date           DateTime @default(now())
  readTime       String   // Ex: "8 min"
  img            String   // Imagem destacada (URL ou caminho do upload local)
  imgFocalPoint  String   @default("center") // Ponto focal CSS da imagem (ex: "center", "top", "50% 50%")

  // Blocos dinâmicos de Texto/Imagem: [{ text: string, image: string, focalPoint: string }]
  blocks         Json     

  // Campos de SEO customizados
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Campos de engajamento
  views          Int      @default(0)
  likes          Int      @default(0)

  // Campos de internacionalização e CMS
  lang                String?  @default("pt")
  translationGroupId  String?  @map("translation_group_id")
  published           Boolean  @default(true)
  imageGenerationSent Boolean  @default(false) @map("image_generation_sent")

  // Contador de citações em outros posts (Link Building interno)
  postsComentados     Int      @default(0) @map("posts_comentados")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comments       Comment[]

  @@index([translationGroupId], map: "idx_post_translation_group")
  @@index([lang], map: "idx_post_lang")
}

model Page {
  id             String   @id @default(uuid())
  slug           String   @unique // Ex: "home", "sobre", "contato"
  title          String
  isStatic       Boolean  @default(false) // Define se é uma página estática estruturada (Home, Sobre) ou customizada

  // Conteúdo estruturado da página (JSON)
  content        Json     

  // Campos de SEO customizados
  seoTitle       String?
  seoDescription String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  comments     Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // REGISTER, COMMENT, LIKE, SHARE
  message   String
  postId    String?
  postTitle String?
  userEmail String?
  userName  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model CalendarioEventos {
  id           Int      @id @default(autoincrement())
  externalId   String   @unique @map("external_id") @db.VarChar(255)
  championship String   @db.VarChar(100)
  seasonYear   Int      @map("season_year")
  eventName    String   @map("event_name") @db.VarChar(255)
  circuitName  String?  @map("circuit_name") @db.VarChar(255)
  countryCode  String?  @map("country_code") @db.VarChar(10)
  dateStart    DateTime? @map("date_start") @db.Timestamptz
  dateEnd      DateTime? @map("date_end") @db.Timestamptz
  status       String   @default("UPCOMING") @db.VarChar(50)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  resultados   ResultadosEtapas[]

  @@index([dateEnd, status], map: "idx_proxima_corrida")
  @@map("calendario_eventos")
}

model RankingPilotos {
  id           Int      @id @default(autoincrement())
  championship String   @db.VarChar(100)
  seasonYear   Int      @map("season_year")
  position     Int
  riderName    String   @map("rider_name") @db.VarChar(255)
  teamName     String?  @map("team_name") @db.VarChar(255)
  constructor  String?  @db.VarChar(100)
  points       Int      @default(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([championship, seasonYear, riderName], name: "uq_ranking_piloto")
  @@map("ranking_pilotos")
}

model ResultadosEtapas {
  id              Int      @id @default(autoincrement())
  eventExternalId String   @map("event_external_id") @db.VarChar(255)
  riderExternalId String?  @map("rider_external_id") @db.VarChar(255)
  sessionType     String   @map("session_type") @db.VarChar(100)
  position        Int?
  riderName       String   @map("rider_name") @db.VarChar(255)
  riderNumber     Int?     @map("rider_number")
  teamName        String?  @map("team_name") @db.VarChar(255)
  constructorName String?  @map("constructor_name") @db.VarChar(100)
  timeResult      String?  @map("time_result") @db.VarChar(50)
  timeGap         String?  @map("time_gap") @db.VarChar(50)
  pointsEarned    Int      @default(0) @map("points_earned")
  totalLaps       Int?     @map("total_laps")
  topSpeed        String?  @map("top_speed") @db.VarChar(50)
  status          String?  @db.VarChar(50)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  event           CalendarioEventos @relation(fields: [eventExternalId], references: [externalId], onDelete: Cascade)

  @@unique([eventExternalId, sessionType, riderName], name: "uq_resultado_piloto")
  @@map("resultados_etapas")
}


